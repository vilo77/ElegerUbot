# Wajib: Dapatkan dari my.telegram.org
API_ID=1234567
API_HASH=abcdef1234567890abcdef
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Wajib minimal 1 session string (dapatkan dari menjalankan session_generator.py)
# Kamu bisa isi sampai STRING_SESSION_20 untuk 20 client
STRING_SESSION_1=your_session_string_here
# STRING_SESSION_2=
# STRING_SESSION_3=

# ID user kamu (Owner)
OWNER_ID=123456789

# Pengaturan Userbot
CMD_HANDLER=.
SUDO_HANDLER=!
SUDO_USERS=123456 987654

# Nama Userbot (opsional)
BOT_NAME=ElegerUbot

# ID Grup/Channel untuk Log Bot (Opsional)
